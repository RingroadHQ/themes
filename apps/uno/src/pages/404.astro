---
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/ui/Button.astro";
import SearchForm from "../components/search/SearchForm.astro";
import { defaultTheme } from "../theme/default";

const theme = defaultTheme;
---

<BaseLayout
  seo={{
    title: "Page Not Found — elora",
    description: "The page you're looking for doesn't exist.",
  }}
  theme={theme}
>
  <div class="container-page py-16 text-center">
    <p class="text-6xl font-heading font-bold text-primary mb-4">404</p>
    <h1 class="text-2xl md:text-3xl font-heading font-bold text-base-content mb-3">
      Page Not Found
    </h1>
    <p class="text-base-300 max-w-md mx-auto mb-8">
      The page you&apos;re looking for doesn&apos;t exist or has been moved.
      Try searching or browse our collections.
    </p>

    <SearchForm class="max-w-md mx-auto mb-8" />

    <div class="flex flex-col sm:flex-row gap-3 justify-center">
      <Button tag="a" href="/" variant="primary">
        Back to Home
      </Button>
      <Button tag="a" href="/products" variant="outline">
        Shop All Wallets
      </Button>
    </div>
  </div>
</BaseLayout>
