---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProductGrid from "../../components/product/ProductGrid.astro";
import Breadcrumbs from "../../components/common/Breadcrumbs.astro";
import CollectionSort from "../../components/collection/CollectionSort.astro";
import { getProducts } from "../../data/api/products";
import { getCollection, getAllCollectionHandles } from "../../data/api/collections";
import { defaultTheme } from "../../theme/default";
import type { SortOption } from "../../utils/constants";

export async function getStaticPaths() {
  const handles = await getAllCollectionHandles();
  return handles.map((handle) => ({ params: { handle } }));
}

const { handle } = Astro.params;
const collection = await getCollection(handle as string);

if (!collection) {
  return Astro.redirect("/404");
}

const url = Astro.url;
const sort = (url.searchParams.get("sort") as SortOption) || "featured";

const { products } = await getProducts({
  collection: handle,
  sort,
});

const theme = defaultTheme;
---

<BaseLayout
  seo={{
    title: collection.seo.title || collection.title,
    description: collection.seo.description || collection.description,
    image: collection.image?.src,
  }}
  theme={theme}
>
  <div class="container-page py-6">
    <Breadcrumbs
      crumbs={[
        { title: "Home", url: "/" },
        { title: "Collections", url: "/collections" },
        { title: collection.title, url: "" },
      ]}
    />
  </div>

  <div class="container-page pb-12">
    <div class="mb-8">
      <h1 class="text-2xl md:text-3xl font-heading font-bold text-base-content">{collection.title}</h1>
      {collection.description && (
        <div class="prose text-base-300 mt-3 max-w-2xl">
          <p>{collection.description}</p>
        </div>
      )}
    </div>

    <div class="flex justify-end mb-6">
      <CollectionSort currentSort={sort} />
    </div>

    <ProductGrid products={products} columns={4} />
  </div>
</BaseLayout>
