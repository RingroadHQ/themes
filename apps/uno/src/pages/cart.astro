---
import BaseLayout from "../layouts/BaseLayout.astro";
import CartSummary from "../components/cart/CartSummary.astro";
import ProductRecommendations from "../components/product/ProductRecommendations.astro";
import Button from "../components/ui/Button.astro";
import Icon from "../components/ui/Icon.astro";
import { defaultTheme } from "../theme/default";
import { getProductRecommendations } from "../data/api/products";
import type { CartItem } from "../data/types";

export const prerender = false;

const theme = defaultTheme;

// The cart page is SSR — cart data is rendered client-side from nanostores
// but we display the page shell for SEO and progressive enhancement
const recs = await getProductRecommendations("prod-001", 4);
---

<BaseLayout
  seo={{
    title: "Your Cart — elora",
    description: "Review the items in your cart and proceed to checkout.",
    noindex: true,
  }}
  theme={theme}
>
  <div class="container-page py-12">
    <h1 class="text-2xl md:text-3xl font-heading font-normal text-base-content mb-8">Your Cart</h1>

    <div id="cart-page-content" class="grid grid-cols-1 lg:grid-cols-[1fr_380px] gap-8">
      <!-- Cart items rendered by client JS -->
      <div data-cart-page-items>
        <div class="text-center py-16 text-base-300">
          <Icon name="cart" size="xl" class="mx-auto mb-3 opacity-30 w-12 h-12" />
          <p class="text-lg font-normal">Your cart is empty</p>
          <p class="text-sm mt-1 mb-6">Looks like you haven't added anything to your cart yet.</p>
          <Button tag="a" href="/products" variant="primary">
            Continue Shopping
          </Button>
        </div>
      </div>

      <div data-cart-page-summary>
        <CartSummary subtotal={0} itemCount={0} />
        <div class="mt-4 space-y-2">
          <a href="/checkout" class="block">
            <Button variant="primary" fullWidth size="lg">
              Proceed to Checkout
            </Button>
          </a>
          <a href="/products" class="block">
            <Button variant="ghost" fullWidth size="md">
              Continue Shopping
            </Button>
          </a>
        </div>
      </div>
    </div>

    <div class="mt-16">
      <ProductRecommendations products={recs} />
    </div>
  </div>
</BaseLayout>

<script>
  // Hydrate cart page with live data from nanostores
  import("../store/cart").then(async ({ items, subtotal, itemCount }) => {
    const container = document.querySelector("[data-cart-page-items]");
    const summaryContainer = document.querySelector("[data-cart-page-summary]");
    const { formatPrice } = await import("../utils/format");

    function render() {
      const list = items.get();
      const count = itemCount.get();
      const sub = subtotal.get();

      if (container) {
        if (list.length === 0) {
          container.innerHTML = `
            <div class="text-center py-16 text-base-300">
              <svg class="mx-auto mb-3 opacity-30 w-12 h-12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
            <p class="text-lg font-normal">Your cart is empty</p>
            <p class="text-sm mt-1 mb-6">Looks like you haven't added anything to your cart yet.</p>
            <a href="/products" class="inline-flex items-center justify-center px-5 py-2.5 bg-primary text-primary-content rounded-md text-sm font-normal hover:opacity-90">Continue Shopping</a>
          </div>`;
        } else {
          container.innerHTML = list.map((item) => `
            <div class="flex gap-4 py-6 border-b border-base-200">
              <a href="/products/${item.handle}" class="flex-shrink-0">
                <img src="${item.image.src}" alt="${item.image.alt}" class="w-28 h-28 rounded-lg object-cover bg-base-200" width="${item.image.width}" height="${item.image.height}" />
              </a>
              <div class="flex-1 min-w-0">
                <a href="/products/${item.handle}" class="text-base font-normal text-base-content hover:underline">${item.title}</a>
                <p class="text-sm text-base-300 mt-0.5">${item.variantTitle}</p>
                <p class="text-sm font-normal mt-2">${formatPrice(item.price)}</p>
                <div class="flex items-center gap-3 mt-3">
                  <div class="flex items-center border border-base-300 rounded-md">
                    <button data-cart-update="${item.id}" data-delta="-1" class="w-8 h-8 flex items-center justify-center text-sm hover:bg-base-200">−</button>
                    <span class="w-8 text-center text-sm">${item.quantity}</span>
                    <button data-cart-update="${item.id}" data-delta="1" class="w-8 h-8 flex items-center justify-center text-sm hover:bg-base-200">+</button>
                  </div>
                  <button data-cart-remove="${item.id}" class="text-sm text-base-300 hover:text-error transition-colors">Remove</button>
                </div>
              </div>
            </div>
          `).join("");

          // Wire up quantity buttons
          container.querySelectorAll<HTMLButtonElement>("[data-cart-update]").forEach((btn) => {
            btn.addEventListener("click", async () => {
              const itemId = btn.dataset.cartUpdate!;
              const delta = parseInt(btn.dataset.delta || "0");
              const { updateItem, removeItem } = await import("../store/cart");
              const currentItems = items.get();
              const item = currentItems.find(i => i.id === itemId);
              if (item && item.quantity + delta <= 0) await removeItem(itemId);
              else await updateItem(itemId, (item?.quantity || 0) + delta);
            });
          });

          // Wire up remove buttons
          container.querySelectorAll<HTMLButtonElement>("[data-cart-remove]").forEach((btn) => {
            btn.addEventListener("click", async () => {
              const { removeItem } = await import("../store/cart");
              await removeItem(btn.dataset.cartRemove!);
            });
          });
        }
      }

      if (summaryContainer) {
        const shipping = sub >= 75 ? 0 : 5.99;
        const tax = Math.round(sub * 0.08 * 100) / 100;
        const total = Math.round((sub + shipping + tax) * 100) / 100;
        summaryContainer.innerHTML = `
          <div class="bg-base-200 rounded-lg p-6 space-y-4">
            <h3 class="text-lg font-heading font-normal text-base-content">Order Summary</h3>
            <div class="space-y-2 text-sm">
              <div class="flex justify-between"><span class="text-base-300">Subtotal (${count} items)</span><span>${formatPrice(sub)}</span></div>
              <div class="flex justify-between"><span class="text-base-300">Shipping</span><span class="${shipping === 0 ? 'text-success' : ''}">${shipping === 0 ? 'Free' : formatPrice(shipping)}</span></div>
              <div class="flex justify-between"><span class="text-base-300">Estimated Tax</span><span>${formatPrice(tax)}</span></div>
            </div>
            <div class="border-t border-base-300 pt-3 flex justify-between text-base font-normal"><span>Total</span><span>${formatPrice(total)}</span></div>
          </div>
          <div class="mt-4 space-y-2">
            <a href="/checkout" class="block w-full text-center px-5 py-2.5 bg-primary text-primary-content rounded-md text-sm font-normal hover:opacity-90">Proceed to Checkout</a>
            <a href="/products" class="block w-full text-center px-5 py-2.5 text-sm text-base-content hover:bg-base-200 rounded-md">Continue Shopping</a>
          </div>`;
      }
    }

    items.subscribe(render);
    render();
  });
</script>
