---
import BaseLayout from "../../layouts/BaseLayout.astro";
import RegisterForm from "../../components/account/RegisterForm.astro";
import { defaultTheme } from "../../theme/default";

export const prerender = false;

const theme = defaultTheme;
---

<BaseLayout
  seo={{
    title: "Create Account — elora",
    description: "Create an account to track orders and manage your profile.",
    noindex: true,
  }}
  theme={theme}
>
  <div class="container-page py-12 flex justify-center">
    <RegisterForm />
  </div>
</BaseLayout>
