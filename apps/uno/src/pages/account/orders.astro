---
import BaseLayout from "../../layouts/BaseLayout.astro";
import AccountNav from "../../components/account/AccountNav.astro";
import OrderHistory from "../../components/account/OrderHistory.astro";
import { defaultTheme } from "../../theme/default";
import { getCustomerOrders } from "../../data/api/account";
import type { Order } from "../../data/types";

export const prerender = false;

const theme = defaultTheme;

// In production: verify auth token and fetch customer orders
const orders: Order[] = [];
---

<BaseLayout
    seo={{
        title: "Order History - elora",
        description: "View your order history and track shipments.",
        noindex: true,
    }}
    theme={theme}
>
    <div class="container-page py-12">
        <h1
            class="text-2xl md:text-3xl font-heading font-normal text-base-content mb-8"
        >
            Order History
        </h1>

        <div class="grid grid-cols-1 md:grid-cols-[200px_1fr] gap-8">
            <AccountNav />
            <OrderHistory orders={orders} />
        </div>
    </div>
</BaseLayout>
