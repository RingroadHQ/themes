---
import Input from "../ui/Input.astro";
import Button from "../ui/Button.astro";
import { cn } from "../../utils/format";

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<div class={cn("max-w-md", className)}>
  <h1 class="text-2xl font-heading font-normal text-base-content mb-6">Sign In</h1>

  <form class="space-y-4" data-login-form>
    <Input label="Email" name="email" type="email" required autocomplete="email" />
    <Input label="Password" name="password" type="password" required autocomplete="current-password" />

    <div class="flex items-center justify-between text-sm">
      <label class="flex items-center gap-2 cursor-pointer">
        <input type="checkbox" name="remember" class="w-4 h-4 rounded border-base-300 text-primary" />
        <span class="text-base-300">Remember me</span>
      </label>
      <a href="/account/forgot-password" class="text-primary hover:underline">Forgot password?</a>
    </div>

    <Button type="submit" variant="primary" fullWidth size="lg" data-login-submit>
      Sign In
    </Button>

    <p class="text-sm text-center text-base-300">
      Don't have an account? <a href="/account/register" class="text-primary hover:underline">Create one</a>
    </p>

    <p class="text-sm text-error hidden" data-login-error></p>
  </form>
</div>

<script>
  document.querySelectorAll<HTMLFormElement>("[data-login-form]").forEach((form) => {
    const errorEl = form.querySelector<HTMLElement>("[data-login-error]");
    const submitBtn = form.querySelector<HTMLButtonElement>("[data-login-submit]");

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.textContent = "Signing in...";
      }

      const formData = new FormData(form);
      const { login } = await import("../../data/api/account");
      const result = await login({
        email: formData.get("email") as string,
        password: formData.get("password") as string,
      });

      if ("error" in result) {
        if (errorEl) {
          errorEl.textContent = result.error;
          errorEl.classList.remove("hidden");
        }
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.textContent = "Sign In";
        }
      } else {
        localStorage.setItem("ringroad:auth-token", result.token);
        window.location.href = "/account";
      }
    });
  });
</script>
