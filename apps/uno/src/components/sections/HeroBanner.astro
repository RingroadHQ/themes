---
import Button from "../ui/Button.astro";
import { cn } from "../../utils/format";

interface Props {
  title: string;
  subtitle: string;
  image: string;
  imageAlt: string;
  ctaText: string;
  ctaUrl: string;
  alignment?: "left" | "center";
  height?: "sm" | "md" | "lg";
}

const { title, subtitle, image, imageAlt, ctaText, ctaUrl, alignment = "left", height = "lg" } = Astro.props;

const heightClasses: Record<string, string> = {
  sm: "min-h-[400px]",
  md: "min-h-[500px]",
  lg: "min-h-[600px]",
};
---

<section class={cn("relative flex items-center overflow-hidden", heightClasses[height])}>
  <img
    src={image}
    alt={imageAlt}
    fetchpriority="high"
    class="absolute inset-0 w-full h-full object-cover"
    width={1600}
    height={900}
  />
  <div class="absolute inset-0 bg-gradient-to-r from-black/60 to-black/20" />
  <div class="relative container-page w-full">
    <div class={cn("max-w-xl", alignment === "center" ? "mx-auto text-center" : "")}>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-heading font-bold text-white leading-tight">
        {title}
      </h1>
      <p class="text-lg text-white/80 mt-4 leading-relaxed max-w-lg">
        {subtitle}
      </p>
      <div class="mt-8">
        <Button tag="a" href={ctaUrl} variant="secondary" size="lg">
          {ctaText}
        </Button>
      </div>
    </div>
  </div>
</section>
