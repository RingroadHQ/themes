---
import Button from "../ui/Button.astro";
import { cn } from "../../utils/format";

interface Props {
  image: string;
  imageAlt: string;
  title: string;
  body: string;
  ctaText?: string;
  ctaUrl?: string;
  imagePosition?: "left" | "right";
}

const { image, imageAlt, title, body, ctaText, ctaUrl, imagePosition = "left" } = Astro.props;
---

<section class="container-page section">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12 items-center">
    {imagePosition === "left" && (
      <div class="relative overflow-hidden rounded-lg bg-base-200 aspect-[4/5] md:aspect-auto md:h-full">
        <img
          src={image}
          alt={imageAlt}
          loading="lazy"
          class="w-full h-full object-cover"
          width={800}
          height={600}
        />
      </div>
    )}
    <div class={cn(imagePosition === "left" ? "md:order-2" : "md:order-1")}>
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-base-content mb-4">
        {title}
      </h2>
      <p class="text-base-300 leading-relaxed">{body}</p>
      {ctaText && ctaUrl && (
        <div class="mt-6">
          <Button tag="a" href={ctaUrl} variant="outline">
            {ctaText}
          </Button>
        </div>
      )}
    </div>
    {imagePosition === "right" && (
      <div class="relative overflow-hidden rounded-lg bg-base-200 aspect-[4/5] md:aspect-auto md:h-full">
        <img
          src={image}
          alt={imageAlt}
          loading="lazy"
          class="w-full h-full object-cover"
          width={800}
          height={600}
        />
      </div>
    )}
  </div>
</section>
