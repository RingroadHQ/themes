---
import type { NavLink } from "../../data/types";
import Icon from "../ui/Icon.astro";
import { isMobileMenuOpen, closeMobileMenu } from "../../store/ui";

interface Props {
  links: NavLink[];
}

const { links } = Astro.props;
---

<div
  id="mobile-menu"
  class="fixed inset-0 z-50 invisible"
  data-mobile-menu
>
  <!-- Backdrop -->
  <div
    class="absolute inset-0 bg-black/50 backdrop-blur-sm opacity-0 transition-opacity duration-300"
    data-mobile-menu-backdrop
  ></div>
  <!-- Panel -->
  <div
    class="absolute top-0 left-0 h-full w-full max-w-sm bg-base-100 shadow-2xl flex flex-col transform -translate-x-full transition-transform duration-300"
    data-mobile-menu-panel
  >
    <div class="flex items-center justify-between p-4 border-b border-base-200">
      <span class="text-lg font-heading font-bold text-base-content">Menu</span>
      <button
        type="button"
        data-mobile-menu-close
        class="p-1 rounded-md text-base-content hover:bg-base-200 transition-colors"
        aria-label="Close menu"
      >
        <Icon name="close" size="md" />
      </button>
    </div>

    <nav class="flex-1 overflow-y-auto p-4" aria-label="Mobile navigation">
      <ul class="flex flex-col gap-1">
        {links.map((link) => (
          <li>
            {link.children && link.children.length > 0 ? (
              <details class="group">
                <summary class="flex items-center justify-between px-3 py-2.5 text-base font-medium text-base-content rounded-md cursor-pointer hover:bg-base-200 transition-colors list-none">
                  {link.title}
                  <Icon name="chevronDown" size="sm" class="group-open:rotate-180 transition-transform" />
                </summary>
                <ul class="ml-4 mt-1 flex flex-col gap-1">
                  {link.children.map((child) => (
                    <li>
                      <a
                        href={child.url}
                        class="block px-3 py-2 text-sm text-base-content hover:bg-base-200 rounded-md transition-colors"
                      >
                        {child.title}
                      </a>
                    </li>
                  ))}
                </ul>
              </details>
            ) : (
              <a
                href={link.url}
                class="block px-3 py-2.5 text-base font-medium text-base-content rounded-md hover:bg-base-200 transition-colors"
              >
                {link.title}
              </a>
            )}
          </li>
        ))}
      </ul>
    </nav>

    <div class="p-4 border-t border-base-200">
      <a href="/account/login" class="block w-full text-center px-4 py-2.5 bg-primary text-primary-content rounded-md text-sm font-medium hover:opacity-90 transition-opacity">
        Sign In
      </a>
    </div>
  </div>
</div>

<script>
  const menu = document.getElementById("mobile-menu")!;
  const backdrop = menu.querySelector<HTMLElement>("[data-mobile-menu-backdrop]")!;
  const panel = menu.querySelector<HTMLElement>("[data-mobile-menu-panel]")!;
  const closeBtn = menu.querySelector<HTMLElement>("[data-mobile-menu-close]")!;

  function open() {
    menu.classList.remove("invisible");
    document.body.style.overflow = "hidden";
    requestAnimationFrame(() => {
      backdrop.classList.remove("opacity-0");
      panel.classList.remove("-translate-x-full");
      panel.classList.add("translate-x-0");
    });
  }

  function close() {
    backdrop.classList.add("opacity-0");
    panel.classList.remove("translate-x-0");
    panel.classList.add("-translate-x-full");
    document.body.style.overflow = "";
    setTimeout(() => {
      menu.classList.add("invisible");
    }, 300);
    closeMobileMenu();
  }

  backdrop.addEventListener("click", close);
  closeBtn.addEventListener("click", close);

  // Expose open/close for the hamburger button
  (window as any).__mobileMenu = { open, close };

  // Listen to store changes
  const isOpenStore = await import("../../store/ui");
  isOpenStore.isMobileMenuOpen.subscribe((val) => {
    if (val) open();
  });
</script>
