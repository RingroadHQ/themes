---
import { isCartOpen } from "../../store/ui";
import Icon from "../ui/Icon.astro";
import Button from "../ui/Button.astro";
import { cn } from "../../utils/format";
---

<div
  id="cart-drawer"
  class="fixed inset-0 z-50 invisible"
  data-cart-drawer
>
  <!-- Backdrop -->
  <div
    class="absolute inset-0 bg-black/50 backdrop-blur-sm opacity-0 transition-opacity duration-300"
    data-cart-backdrop
  ></div>
  <!-- Panel -->
  <div
    class="absolute top-0 right-0 h-full w-full max-w-md bg-base-100 shadow-2xl flex flex-col transform translate-x-full transition-transform duration-300"
    data-cart-panel
  >
    <div class="flex items-center justify-between p-4 border-b border-base-200">
      <h2 class="text-lg font-heading font-bold text-base-content">
        Your Cart
        <span class="text-sm font-normal text-base-300 ml-1" data-cart-item-count></span>
      </h2>
      <button
        type="button"
        data-cart-close
        class="p-1 rounded-md text-base-content hover:bg-base-200 transition-colors"
        aria-label="Close cart"
      >
        <Icon name="close" size="md" />
      </button>
    </div>

    <div class="flex-1 overflow-y-auto p-4" data-cart-items-container>
      <!-- Items rendered by client JS -->
      <div class="text-center py-12 text-base-300">
        <Icon name="cart" size="xl" class="mx-auto mb-3 opacity-30" />
        <p class="text-lg font-medium">Your cart is empty</p>
        <p class="text-sm mt-1">Add some wallets to get started.</p>
      </div>
    </div>

    <div class="border-t border-base-200 p-4 space-y-3" data-cart-footer>
      <div class="flex justify-between items-center text-sm">
        <span class="text-base-300">Subtotal</span>
        <span class="font-semibold text-base-content" data-cart-subtotal>$0.00</span>
      </div>
      <p class="text-xs text-base-300">Shipping and taxes calculated at checkout.</p>
      <a href="/cart" class="block">
        <Button variant="outline" fullWidth size="md">
          View Cart
        </Button>
      </a>
      <a href="/checkout" class="block">
        <Button variant="primary" fullWidth size="md">
          Checkout
        </Button>
      </a>
    </div>
  </div>
</div>

<script>
  const drawer = document.getElementById("cart-drawer")!;
  const backdrop = drawer.querySelector<HTMLElement>("[data-cart-backdrop]")!;
  const panel = drawer.querySelector<HTMLElement>("[data-cart-panel]")!;
  const closeBtn = drawer.querySelector<HTMLElement>("[data-cart-close]")!;

  function open() {
    drawer.classList.remove("invisible");
    document.body.style.overflow = "hidden";
    requestAnimationFrame(() => {
      backdrop.classList.remove("opacity-0");
      panel.classList.remove("translate-x-full");
      panel.classList.add("translate-x-0");
    });
    renderCartItems();
  }

  function close() {
    backdrop.classList.add("opacity-0");
    panel.classList.remove("translate-x-0");
    panel.classList.add("translate-x-full");
    document.body.style.overflow = "";
    setTimeout(() => {
      drawer.classList.add("invisible");
    }, 300);
  }

  backdrop.addEventListener("click", close);
  closeBtn.addEventListener("click", close);

  // Listen to store
  import("../../store/ui").then(({ isCartOpen: openStore }) => {
    openStore.subscribe((val) => {
      if (val) open(); else close();
    });
  });

  async function renderCartItems() {
    const { items } = await import("../../store/cart");
    const container = drawer.querySelector("[data-cart-items-container]");
    const countEl = drawer.querySelector("[data-cart-item-count]");
    const subtotalEl = drawer.querySelector("[data-cart-subtotal]");
    const { formatPrice } = await import("../../utils/format");

    function update() {
      const list = items.get();
      const count = list.reduce((s, i) => s + i.quantity, 0);
      const subtotal = list.reduce((s, i) => s + i.price * i.quantity, 0);

      if (countEl) countEl.textContent = `(${count} item${count !== 1 ? "s" : ""})`;
      if (subtotalEl) subtotalEl.textContent = formatPrice(subtotal);

      if (container) {
        if (list.length === 0) {
          container.innerHTML = `
            <div class="text-center py-12 text-base-300">
              <svg class="mx-auto mb-3 opacity-30 w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
              <p class="text-lg font-medium">Your cart is empty</p>
            </div>`;
        } else {
          container.innerHTML = list.map((item) => `
            <div class="flex gap-3 py-3 border-b border-base-200">
              <img src="${item.image.src}" alt="${item.image.alt}" class="w-20 h-20 rounded-md object-cover bg-base-200" width="${item.image.width}" height="${item.image.height}" />
              <div class="flex-1 min-w-0">
                <a href="/products/${item.handle}" class="text-sm font-medium text-base-content hover:underline line-clamp-1">${item.title}</a>
                <p class="text-xs text-base-300 mt-0.5">${item.variantTitle}</p>
                <div class="flex items-center justify-between mt-2">
                  <span class="text-sm font-medium">${formatPrice(item.price)}</span>
                  <div class="flex items-center gap-2">
                    <button data-cart-update="${item.id}" data-delta="-1" class="w-6 h-6 flex items-center justify-center rounded border border-base-300 text-sm hover:bg-base-200 transition-colors">−</button>
                    <span class="text-sm w-6 text-center">${item.quantity}</span>
                    <button data-cart-update="${item.id}" data-delta="1" class="w-6 h-6 flex items-center justify-center rounded border border-base-300 text-sm hover:bg-base-200 transition-colors">+</button>
                  </div>
                </div>
              </div>
            </div>
          `).join("");

          // Wire up update buttons
          container.querySelectorAll<HTMLButtonElement>("[data-cart-update]").forEach((btn) => {
            btn.addEventListener("click", async () => {
              const itemId = btn.dataset.cartUpdate!;
              const delta = parseInt(btn.dataset.delta || "0");
              const { updateItem, removeItem } = await import("../../store/cart");
              const currentItems = (await import("../../store/cart")).items.get();
              const item = currentItems.find(i => i.id === itemId);
              if (item && item.quantity + delta <= 0) {
                await removeItem(itemId);
              } else {
                await updateItem(itemId, item!.quantity + delta);
              }
              update();
            });
          });
        }
      }
    }

    items.subscribe(update);
    update();
  }
</script>
