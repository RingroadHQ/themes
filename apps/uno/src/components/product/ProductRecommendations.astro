---
import type { Product } from "../../data/types";
import ProductCard from "./ProductCard.astro";
import { cn } from "../../utils/format";

interface Props {
  products: Product[];
  title?: string;
  class?: string;
}

const { products, title = "You May Also Like", class: className } = Astro.props;

if (products.length === 0) return;
---

<div class={cn("section", className)}>
  <h2 class="text-2xl font-heading font-bold text-base-content mb-8">{title}</h2>
  <div class="grid grid-cols-2 md:grid-cols-4 gap-x-4 gap-y-8">
    {products.slice(0, 4).map((product) => (
      <ProductCard product={product} showRating={false} />
    ))}
  </div>
</div>
