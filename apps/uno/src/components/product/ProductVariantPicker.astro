---
import type { ProductOption } from "../../data/types";
import { cn } from "../../utils/format";

interface Props {
  options: ProductOption[];
  selectedOptions: Record<string, string>;
  onSelect: (name: string, value: string) => void;
  class?: string;
}

const { options, selectedOptions, onSelect, class: className } = Astro.props;

// Determine if an option should render as color swatches
const colorNames = ["color", "colour", "farbe"];
const isColorOption = (name: string) =>
  colorNames.includes(name.toLowerCase());

// Color swatch mapping
const colorMap: Record<string, string> = {
  black: "#1a1a1a",
  brown: "#6b4423",
  tan: "#c49a6c",
  navy: "#1e3a4d",
  burgundy: "#6b1d2f",
  olive: "#556b2f",
  "dark brown": "#3d2c1e",
  "antique brown": "#8b6914",
  "distressed black": "#2d2d2d",
  "brown & tan": "#c49a6c",
  "black & gray": "#4a4a4a",
  "navy & brown": "#3d2c1e",
  "polished copper": "#c47a4a",
  "brushed copper": "#b87351",
  "color #8 (burgundy)": "#6b1d2f",
  "dark cognac": "#8b4513",
  "forged carbon": "#3d3d3d",
  "coyote brown": "#8b7355",
  "olive drab": "#556b2f",
};
---

<div class={cn("space-y-4", className)} data-variant-picker>
  {options.map((option) => (
    <fieldset>
      <legend class="text-sm font-normal text-base-content mb-2">
        {option.name}: <span class="font-normal text-base-300">{selectedOptions[option.name] || "Select"}</span>
      </legend>
      {isColorOption(option.name) ? (
        <!-- Color swatches -->
        <div class="flex flex-wrap gap-2">
          {option.values.map((val) => {
            const isSelected = selectedOptions[option.name] === val;
            const swatchColor = colorMap[val.toLowerCase()] || "#888";
            return (
              <button
                type="button"
                data-option-name={option.name}
                data-option-value={val}
                class={cn(
                  "w-9 h-9 rounded-full border-2 transition-all relative",
                  isSelected ? "border-primary ring-2 ring-primary/30" : "border-base-300 hover:border-base-content"
                )}
                style={`background-color: ${swatchColor}`}
                aria-label={val}
                title={val}
              >
                {isSelected && (
                  <span class="absolute inset-0 flex items-center justify-center">
                    <span class="w-3 h-3 bg-white/90 rounded-full" />
                  </span>
                )}
              </button>
            );
          })}
        </div>
      ) : (
        <!-- Text-based options (buttons) -->
        <div class="flex flex-wrap gap-2">
          {option.values.map((val) => {
            const isSelected = selectedOptions[option.name] === val;
            return (
              <button
                type="button"
                data-option-name={option.name}
                data-option-value={val}
                class={cn(
                  "px-4 py-2 text-sm rounded-md border transition-all",
                  isSelected
                    ? "border-primary bg-primary/5 text-primary font-normal"
                    : "border-base-300 text-base-content hover:border-base-content"
                )}
              >
                {val}
              </button>
            );
          })}
        </div>
      )}
    </fieldset>
  ))}
</div>

<script>
  // Handle option selection and emit change events
  document.querySelectorAll<HTMLElement>("[data-variant-picker]").forEach((picker) => {
    picker.querySelectorAll<HTMLButtonElement>("button[data-option-name]").forEach((btn) => {
      btn.addEventListener("click", () => {
        const name = btn.dataset.optionName!;
        const value = btn.dataset.optionValue!;

        // Update selected state for this option group
        picker
          .querySelectorAll<HTMLButtonElement>(`button[data-option-name="${name}"]`)
          .forEach((b) => {
            b.classList.remove("border-primary", "bg-primary/5", "text-primary", "ring-2", "ring-primary/30");
            b.classList.add("border-base-300", "text-base-content");
          });

        btn.classList.add("border-primary", "bg-primary/5", "text-primary");
        btn.classList.remove("border-base-300", "text-base-content");

        // Dispatch change event
        picker.dispatchEvent(
          new CustomEvent("variant-change", {
            detail: { name, value },
            bubbles: true,
          })
        );
      });
    });
  });
</script>
