---
import { SORT_OPTIONS } from "../../utils/constants";
import type { SortOption } from "../../utils/constants";
import Select from "../ui/Select.astro";
import { cn } from "../../utils/format";

interface Props {
  currentSort?: SortOption;
  class?: string;
}

const { currentSort = "featured", class: className } = Astro.props;

const options = SORT_OPTIONS.map((opt) => ({
  value: opt.value,
  label: opt.label,
}));
---

<div class={cn("w-full sm:w-auto", className)} data-sort-container>
  <Select
    label="Sort by"
    name="sort"
    options={options}
    value={currentSort}
  />
</div>

<script>
  document.querySelectorAll<HTMLElement>("[data-sort-container] select").forEach((select) => {
    select.addEventListener("change", () => {
      const url = new URL(window.location.href);
      url.searchParams.set("sort", select.value);
      window.location.href = url.toString();
    });
  });
</script>
