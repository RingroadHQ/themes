---
import { formatPrice } from "../../utils/format";
import { cn } from "../../utils/format";

interface Props {
  price: number;
  compareAtPrice?: number | null;
  currency?: string;
  size?: "sm" | "md" | "lg";
  class?: string;
}

const {
  price,
  compareAtPrice,
  currency = "USD",
  size = "md",
  class: className,
} = Astro.props;

const hasSale = compareAtPrice && compareAtPrice > price;

const sizeClasses: Record<string, string> = {
  sm: "text-sm",
  md: "text-base",
  lg: "text-xl",
};
---

<span class={cn("inline-flex items-baseline gap-2", sizeClasses[size], className)}>
  <span
    class={hasSale ? "text-error font-semibold" : "text-base-content font-semibold"}
    aria-label={`Price: ${formatPrice(price, currency)}`}
  >
    {formatPrice(price, currency)}
  </span>
  {hasSale && (
    <span
      class="text-base-300 line-through text-sm"
      aria-label={`Compare at price: ${formatPrice(compareAtPrice, currency)}`}
    >
      {formatPrice(compareAtPrice, currency)}
    </span>
  )}
</span>
