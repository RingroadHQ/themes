---
import { cn } from "../../utils/format";

interface Props {
  width?: string;
  height?: string;
  rounded?: "sm" | "md" | "lg" | "full";
  class?: string;
}

const {
  width = "100%",
  height = "1rem",
  rounded = "md",
  class: className,
} = Astro.props;

const roundedClasses: Record<string, string> = {
  sm: "rounded-sm",
  md: "rounded-md",
  lg: "rounded-lg",
  full: "rounded-full",
};
---

<div
  class={cn(
    "animate-pulse bg-base-300",
    roundedClasses[rounded],
    className
  )}
  style={`width: ${width}; height: ${height};`}
  aria-hidden="true"
>
  &nbsp;
</div>
