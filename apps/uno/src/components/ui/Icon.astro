const svgContent = icons[name] || "";
const classes = cn(sizeClasses[size], className);
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width="24"
  height="24"
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width={strokeWidth}
  stroke-linecap="round"
  stroke-linejoin="round"
  class={classes}
  aria-hidden="true"
>
  <Fragment set:html={svgContent} />
</svg>
