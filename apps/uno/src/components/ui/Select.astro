---
import { cn } from "../../utils/format";

interface Props {
  label: string;
  name: string;
  options: { value: string; label: string }[];
  value?: string;
  required?: boolean;
  error?: string;
  class?: string;
}

const {
  label,
  name,
  options,
  value,
  required = false,
  error,
  class: className,
} = Astro.props;

const selectId = `select-${name}`;
const errorId = `error-${name}`;
---

<div class={cn("flex flex-col gap-1.5", className)}>
  <label for={selectId} class="text-sm font-normal text-base-content">
    {label}
    {required && <span class="text-error ml-0.5" aria-hidden="true">*</span>}
  </label>
  <select
    id={selectId}
    name={name}
    required={required}
    aria-invalid={error ? "true" : "false"}
    aria-describedby={error ? errorId : undefined}
    class={cn(
      "w-full px-3 py-2.5 text-sm rounded-md border bg-base-100 text-base-content",
      "focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary",
      "transition-colors duration-200 appearance-none",
      "bg-[url('data:image/svg+xml;charset=utf-8,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20viewBox%3D%220%200%2020%2020%22%20fill%3D%22%236b7280%22%3E%3Cpath%20fill-rule%3D%22evenodd%22%20d%3D%22M5.23%207.21a.75.75%200%20011.06.02L10%2011.168l3.71-3.938a.75.75%200%20111.08%201.04l-4.25%204.5a.75.75%200%2001-1.08%200l-4.25-4.5a.75.75%200%2001.02-1.06z%22%2F%3E%3C%2Fsvg%3E')]",
      "bg-[length:1.25rem] bg-[right_0.5rem_center] bg-no-repeat pr-8",
      error ? "border-error" : "border-base-300"
    )}
  >
    {options.map((opt) => (
      <option value={opt.value} selected={opt.value === value}>
        {opt.label}
      </option>
    ))}
  </select>
  {error && (
    <p id={errorId} class="text-sm text-error" role="alert">
      {error}
    </p>
  )}
</div>
